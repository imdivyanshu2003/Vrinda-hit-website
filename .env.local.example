# ============================================================
#  VRINDA HIT — Environment variables
#  Copy this file to `.env.local` for local dev, and add the same
#  vars in Vercel → Project → Settings → Environment Variables
#  for production.
# ============================================================

# --- Anthropic (Claude) — required for AI site generation ---
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Which Claude model to use. Defaults to haiku for speed on Vercel Hobby.
# Options:
#   claude-haiku-4-5    — fast (15-25s), cheap (~₹3/site). Works on Vercel Hobby.
#   claude-sonnet-4-5   — premium (30-50s, ~₹10/site). Needs Vercel Pro (300s timeout).
#   claude-opus-4-5     — overkill (60-120s). Needs Vercel Pro. Only use for "Ultra" tier.
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Supabase — required for storage + orders/sites database ---
# Create a project at https://supabase.com/dashboard
# Then: Project Settings → API → copy these 2 values:
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...   # Service role (secret, server-only)

# Bucket name where generated HTML files live. Defaults to "sites".
SUPABASE_SITES_BUCKET=sites

# --- Internal API gate (optional but recommended) ---
# If set, /api/generate will require header `x-internal-secret: <value>`.
# Leave empty during initial testing, set when you wire up Razorpay.
INTERNAL_API_SECRET=

# --- Cashfree Payments (Production) ---
# Dashboard → Developers → API Keys (pick Test for sandbox, Production for live)
CASHFREE_MODE=PROD            # Cashfree Payments (Production)
# Get these from https://dashboard.cashfree.com/apikeys
CASHFREE_APP_ID=your_production_app_id_here
CASHFREE_SECRET_KEY=your_production_secret_key_here
# Webhook signature is HMAC-SHA256 of (timestamp + rawBody) using your secret key

# --- Razorpay (optional fallback, not used currently) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Resend (email notifications, Phase 2) ---
RESEND_API_KEY=

# --- Admin dashboard password (Phase 3) ---
ADMIN_PASSWORD=
